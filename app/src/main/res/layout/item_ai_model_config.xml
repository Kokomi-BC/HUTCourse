<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAiModel"
    style="@style/Widget.MyApplication.SettingsCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="74dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tvModelOrder"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="1"
            android:textColor="?attr/colorOnSurface"
            android:textSize="21sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvModelName"
                style="@style/Widget.MyApplication.SettingsRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="gpt-4o-mini" />

            <TextView
                android:id="@+id/tvModelMeta"
                style="@style/Widget.MyApplication.SettingsRowSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="openaisdk · deepseek-chat · 已配置密钥" />

            <TextView
                android:id="@+id/tvModelCapability"
                style="@style/Widget.MyApplication.SettingsRowSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:text="文本模型"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivDragHandle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="拖动排序"
            android:padding="6dp"
            android:src="@drawable/ic_menu_left"
            android:tint="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnModelMore"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="更多操作"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            android:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
