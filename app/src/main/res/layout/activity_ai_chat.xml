<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootAiChat"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAiStatus"
            style="@style/Widget.MyApplication.SettingsRowSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="当前模式" />

        <ScrollView
            android:id="@+id/chatScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:paddingTop="4dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/composerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeColor="#35FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp">

                <EditText
                    android:id="@+id/etPrompt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="输入消息，或 /note 记录事项"
                    android:gravity="start|center_vertical"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="8"
                    android:minHeight="44dp"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#88FFFFFF" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_send_circle"
                    android:contentDescription="发送"
                    android:padding="10dp"
                    android:src="@drawable/ic_send_up"
                    android:tint="@android:color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
