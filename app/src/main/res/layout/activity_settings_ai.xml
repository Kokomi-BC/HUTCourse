<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSettingsAi"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="大模型设置" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <TextView
            style="@style/Widget.MyApplication.SettingsRowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="模型设置" />

        <TextView
            style="@style/Widget.MyApplication.SettingsRowSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="维护默认模型优先级，并按需开启具体技能。" />

        <TextView
            style="@style/Widget.MyApplication.SettingsRowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="模型列表与优先级" />

        <TextView
            style="@style/Widget.MyApplication.SettingsRowSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="拖动列表调整优先级，排序第1的模型将作为默认模型。" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:minHeight="140dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAiModels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="ifContentScrolls"
                android:paddingBottom="6dp"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/tvAiModelsEmpty"
                style="@style/Widget.MyApplication.SettingsRowSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="18dp"
                android:text="暂无模型，点击下方按钮添加"
                android:visibility="gone" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAiModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="18dp"
            android:text="添加模型"
            android:textAllCaps="false"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <TextView
            style="@style/Widget.MyApplication.SettingsRowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="技能设置" />

        <TextView
            style="@style/Widget.MyApplication.SettingsRowSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="按需开启具体技能，减少不必要的工具调用。" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCoreSkillToggles"
            style="@style/Widget.MyApplication.SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchNoteSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="笔记技能（note）" />

                <TextView
                    android:id="@+id/tvNoteSkillSummary"
                    style="@style/Widget.MyApplication.SettingsRowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="记录与读取长期记忆。" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchCourseSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="课表技能（course）" />

                <TextView
                    android:id="@+id/tvCourseSkillSummary"
                    style="@style/Widget.MyApplication.SettingsRowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="查询今日/指定日期课程。" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchNavigationSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="导航技能（navigation）" />

                <TextView
                    android:id="@+id/tvNavigationSkillSummary"
                    style="@style/Widget.MyApplication.SettingsRowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="地点搜索、定位与路线估算。" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchClassroomSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="空教室技能（classroom）" />

                <TextView
                    android:id="@+id/tvClassroomSkillSummary"
                    style="@style/Widget.MyApplication.SettingsRowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="查询空教室与教室今日使用。" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAgendaSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="日程技能（agenda）" />

                <TextView
                    android:id="@+id/tvAgendaSkillSummary"
                    style="@style/Widget.MyApplication.SettingsRowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="新增、查询、更新、删除日程。" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWebSearchSkill"
            style="@style/Widget.MyApplication.SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchWebSearchSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="联网搜索技能" />

                <TextView
                    android:id="@+id/tvWebSearchSkillSummary"
                    style="@style/Widget.MyApplication.SettingsRowSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="关闭状态，开启后可配置 Tavily API。" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layoutTavilyConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                style="@style/Widget.MyApplication.SettingsRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tavily 配置" />

            <TextView
                android:id="@+id/tvTavilyConfigSummary"
                style="@style/Widget.MyApplication.SettingsRowSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="未配置 Tavily API Key" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTavilyConfig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="18dp"
                android:text="编辑 Tavily 配置"
                android:textAllCaps="false" />
        </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
